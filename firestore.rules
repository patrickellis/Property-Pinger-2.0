rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /properties/{propertyId} {
      // Anyone can read property data
      allow read: if true;
      
      // Only allow updating the CRM fields, prevent creating/deleting or modifying other fields
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pinned', 'user_status', 'user_note', 'ignored']);
      allow create, delete: if false;
    }
    
    // Deny access to everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
